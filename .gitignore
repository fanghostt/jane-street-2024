# Data — never commit competition data
data/raw/*
data/interim/*
data/features/*

# Kaggle credentials & downloaded archives — never commit
kaggle.json
**/kaggle.json
*.zip

# Run & experiment artifacts (gitignored; recreated on run).
# - outputs/ : standard pipeline single-run artifacts (oof, reports, submissions)
# - experiments/ : experiment runs (split sweeps, incremental-vs-full, cadence sweeps)
models/*
outputs/*
/experiments/

# Keep the directory structure
!.gitkeep

# Python
__pycache__/
*.pyc
.pytest_cache/

# Virtual environments
.venv/
venv/

# Env / misc
.env
.DS_Store

# Weights & Biases run artifacts
wandb/
